       IDENTIFICATION DIVISION.
       PROGRAM-ID. PROG002.
       AUTHOR. DATA-LINEAGE-TEAM.
      *
      *  PROG002: Transaction File Validation
      *  PURPOSE: Reads TRANSACTION-FILE (from TRANIN DD),
      *           validates transactions, writes valid records to
      *           VALID-TRANS-OUTPUT (VALIDOUT DD) and rejects to
      *           REJECT.TRANS.FILE (REJECTDS DD).
      *
       ENVIRONMENT DIVISION.
       CONFIGURATION SECTION.
       SOURCE-COMPUTER. IBM-3090.
       OBJECT-COMPUTER. IBM-3090.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.
           SELECT TRANSACTION-FILE
               ASSIGN TO TRANIN
               ORGANIZATION IS SEQUENTIAL
               ACCESS MODE IS SEQUENTIAL
               FILE STATUS IS WS-TRAN-FILE-STATUS.
           SELECT VALID-TRANS-OUTPUT
               ASSIGN TO VALIDOUT
               ORGANIZATION IS SEQUENTIAL
               ACCESS MODE IS SEQUENTIAL
               FILE STATUS IS WS-VALID-FILE-STATUS.
           SELECT REJECT-TRANS-FILE
               ASSIGN TO REJECTDS
               ORGANIZATION IS SEQUENTIAL
               ACCESS MODE IS SEQUENTIAL
               FILE STATUS IS WS-REJECT-FILE-STATUS.

       DATA DIVISION.
       FILE SECTION.
       FD  TRANSACTION-FILE
           RECORDING MODE IS F
           RECORD CONTAINS 250 CHARACTERS.
       01  TRANS-INPUT-RECORD.
           COPY TRANS-REC.

       FD  VALID-TRANS-OUTPUT
           RECORDING MODE IS F
           RECORD CONTAINS 250 CHARACTERS.
       01  VALID-TRANS-RECORD.
           05  VT-TRANSACTION-ID    PIC X(12).
           05  VT-ACCOUNT-NUMBER    PIC 9(10).
           05  VT-TRANS-DATE        PIC X(8).
           05  VT-TRANS-TIME        PIC X(6).
           05  VT-TRANS-TYPE        PIC X(4).
           05  VT-AMOUNT            PIC S9(11)V99 COMP-3.
           05  VT-CURRENCY-CODE     PIC X(3).
           05  VT-MERCHANT-ID       PIC X(20).
           05  VT-MERCHANT-CAT      PIC X(4).
           05  VT-AUTH-CODE         PIC X(6).
           05  VT-STATUS            PIC X(2).
           05  VT-RISK-SCORE        PIC 9(3)V99 COMP-3.
           05  VT-FILLER            PIC X(155).

       FD  REJECT-TRANS-FILE
           RECORDING MODE IS F
           RECORD CONTAINS 250 CHARACTERS.
       01  REJECT-TRANS-RECORD.
           05  RJ-TRANSACTION-ID    PIC X(12).
           05  RJ-ACCOUNT-NUMBER    PIC 9(10).
           05  RJ-REJECT-CODE       PIC X(4).
           05  RJ-REJECT-REASON     PIC X(60).
           05  RJ-ORIGINAL-RECORD   PIC X(174).

       WORKING-STORAGE SECTION.
       01  WS-FILE-STATUS-FLAGS.
           05  WS-TRAN-FILE-STATUS   PIC XX VALUE SPACES.
           05  WS-VALID-FILE-STATUS  PIC XX VALUE SPACES.
           05  WS-REJECT-FILE-STATUS PIC XX VALUE SPACES.

       01  WS-CONTROL-FIELDS.
           05  WS-INPUT-COUNT       PIC 9(9) COMP VALUE ZERO.
           05  WS-VALID-COUNT       PIC 9(9) COMP VALUE ZERO.
           05  WS-REJECT-COUNT      PIC 9(5) COMP VALUE ZERO.
           05  WS-EOF-FLAG          PIC X    VALUE 'N'.
               88  EOF-REACHED      VALUE 'Y'.
           05  WS-VALID-FLAG        PIC X    VALUE 'Y'.
               88  RECORD-VALID     VALUE 'Y'.
               88  RECORD-INVALID   VALUE 'N'.

       01  WS-VALIDATION-FIELDS.
           05  WS-TRANS-ID          PIC X(12) VALUE SPACES.
           05  WS-ACCT-NUM          PIC 9(10) VALUE ZERO.
           05  WS-TRANS-AMOUNT      PIC S9(11)V99 COMP-3 VALUE ZERO.
           05  WS-RISK-SCORE-WORK   PIC 9(3)V99 COMP-3 VALUE ZERO.
           05  WS-REJECT-CODE       PIC X(4) VALUE SPACES.
           05  WS-REJECT-REASON     PIC X(60) VALUE SPACES.
           05  WS-MAX-TRANS-AMT     PIC S9(11)V99 COMP-3 VALUE 999999.99.
           05  WS-HIGH-RISK-SCORE   PIC 9(3)V99 COMP-3 VALUE 85.00.

       PROCEDURE DIVISION.
       0000-MAIN-CONTROL.
           PERFORM 1000-INITIALIZE
           PERFORM 2000-PROCESS-TRANSACTIONS
               UNTIL EOF-REACHED
           PERFORM 3000-FINALIZE
           STOP RUN.

       1000-INITIALIZE.
           OPEN INPUT  TRANSACTION-FILE
           OPEN OUTPUT VALID-TRANS-OUTPUT
           OPEN OUTPUT REJECT-TRANS-FILE
           READ TRANSACTION-FILE
               AT END MOVE 'Y' TO WS-EOF-FLAG
           END-READ.

       2000-PROCESS-TRANSACTIONS.
           ADD 1 TO WS-INPUT-COUNT
           MOVE 'Y' TO WS-VALID-FLAG
           PERFORM 2100-VALIDATE-TRANSACTION
           IF RECORD-VALID
               PERFORM 2200-WRITE-VALID-RECORD
           ELSE
               PERFORM 2300-WRITE-REJECT-RECORD
           END-IF
           PERFORM 2400-READ-NEXT.

       2100-VALIDATE-TRANSACTION.
           MOVE TI-TRANSACTION-ID  TO WS-TRANS-ID
           MOVE TI-ACCOUNT-NUMBER  TO WS-ACCT-NUM
           MOVE TI-AMOUNT          TO WS-TRANS-AMOUNT
           COMPUTE WS-RISK-SCORE-WORK = TI-RISK-SCORE
           IF TI-TRANSACTION-ID = SPACES
               MOVE 'N'     TO WS-VALID-FLAG
               MOVE 'V001'  TO WS-REJECT-CODE
               MOVE 'MISSING TRANSACTION ID' TO WS-REJECT-REASON
           END-IF
           IF TI-ACCOUNT-NUMBER = ZERO
               MOVE 'N'     TO WS-VALID-FLAG
               MOVE 'V002'  TO WS-REJECT-CODE
               MOVE 'INVALID ACCOUNT NUMBER' TO WS-REJECT-REASON
           END-IF
           IF WS-TRANS-AMOUNT > WS-MAX-TRANS-AMT
               MOVE 'N'     TO WS-VALID-FLAG
               MOVE 'V003'  TO WS-REJECT-CODE
               MOVE 'AMOUNT EXCEEDS MAXIMUM LIMIT' TO WS-REJECT-REASON
           END-IF
           IF WS-RISK-SCORE-WORK > WS-HIGH-RISK-SCORE
               MOVE 'N'     TO WS-VALID-FLAG
               MOVE 'V004'  TO WS-REJECT-CODE
               MOVE 'HIGH RISK SCORE - MANUAL REVIEW' TO WS-REJECT-REASON
           END-IF.

       2200-WRITE-VALID-RECORD.
           MOVE TI-TRANSACTION-ID  TO VT-TRANSACTION-ID
           MOVE TI-ACCOUNT-NUMBER  TO VT-ACCOUNT-NUMBER
           MOVE TI-TRANS-DATE      TO VT-TRANS-DATE
           MOVE TI-TRANS-TIME      TO VT-TRANS-TIME
           MOVE TI-TRANS-TYPE      TO VT-TRANS-TYPE
           MOVE WS-TRANS-AMOUNT    TO VT-AMOUNT
           MOVE TI-CURRENCY-CODE   TO VT-CURRENCY-CODE
           MOVE TI-MERCHANT-ID     TO VT-MERCHANT-ID
           MOVE TI-MERCHANT-CAT    TO VT-MERCHANT-CAT
           MOVE TI-AUTH-CODE       TO VT-AUTH-CODE
           MOVE 'VA'               TO VT-STATUS
           MOVE WS-RISK-SCORE-WORK TO VT-RISK-SCORE
           MOVE SPACES             TO VT-FILLER
           WRITE VALID-TRANS-RECORD
           ADD 1 TO WS-VALID-COUNT.

       2300-WRITE-REJECT-RECORD.
           MOVE WS-TRANS-ID        TO RJ-TRANSACTION-ID
           MOVE WS-ACCT-NUM        TO RJ-ACCOUNT-NUMBER
           MOVE WS-REJECT-CODE     TO RJ-REJECT-CODE
           MOVE WS-REJECT-REASON   TO RJ-REJECT-REASON
           MOVE TRANS-INPUT-RECORD TO RJ-ORIGINAL-RECORD
           WRITE REJECT-TRANS-RECORD
           ADD 1 TO WS-REJECT-COUNT.

       2400-READ-NEXT.
           READ TRANSACTION-FILE
               AT END MOVE 'Y' TO WS-EOF-FLAG
           END-READ.

       3000-FINALIZE.
           CLOSE TRANSACTION-FILE
           CLOSE VALID-TRANS-OUTPUT
           CLOSE REJECT-TRANS-FILE
           DISPLAY 'PROG002: INPUT  RECORDS = ' WS-INPUT-COUNT
           DISPLAY 'PROG002: VALID  RECORDS = ' WS-VALID-COUNT
           DISPLAY 'PROG002: REJECT RECORDS = ' WS-REJECT-COUNT.
