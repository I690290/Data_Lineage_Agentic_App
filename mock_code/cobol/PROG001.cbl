       IDENTIFICATION DIVISION.
       PROGRAM-ID. PROG001.
       AUTHOR. DATA-LINEAGE-TEAM.
      *
      *  PROG001: Account Master File Extraction
      *  PURPOSE: Reads ACCOUNT-MASTER-FILE (from INFILE DD),
      *           transforms account records, writes to ACCOUNT-OUTPUT
      *           (OUTFILE DD) for downstream SQL loading.
      *
       ENVIRONMENT DIVISION.
       CONFIGURATION SECTION.
       SOURCE-COMPUTER. IBM-3090.
       OBJECT-COMPUTER. IBM-3090.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.
           SELECT ACCOUNT-MASTER-FILE
               ASSIGN TO INFILE
               ORGANIZATION IS SEQUENTIAL
               ACCESS MODE IS SEQUENTIAL
               FILE STATUS IS WS-ACCT-FILE-STATUS.
           SELECT ACCOUNT-OUTPUT-FILE
               ASSIGN TO OUTFILE
               ORGANIZATION IS SEQUENTIAL
               ACCESS MODE IS SEQUENTIAL
               FILE STATUS IS WS-OUT-FILE-STATUS.

       DATA DIVISION.
       FILE SECTION.
       FD  ACCOUNT-MASTER-FILE
           RECORDING MODE IS F
           RECORD CONTAINS 200 CHARACTERS.
       01  ACCT-MASTER-RECORD.
           COPY ACCT-REC.

       FD  ACCOUNT-OUTPUT-FILE
           RECORDING MODE IS F
           RECORD CONTAINS 200 CHARACTERS.
       01  ACCT-OUTPUT-RECORD.
           05  AO-ACCOUNT-NUMBER    PIC 9(10).
           05  AO-CUSTOMER-NAME     PIC X(40).
           05  AO-ACCOUNT-TYPE      PIC X(5).
           05  AO-BALANCE           PIC S9(13)V99 COMP-3.
           05  AO-OPEN-DATE         PIC X(8).
           05  AO-STATUS-CODE       PIC X(2).
           05  AO-CREDIT-LIMIT      PIC S9(11)V99 COMP-3.
           05  AO-BRANCH-CODE       PIC X(4).
           05  AO-PRODUCT-CODE      PIC X(6).
           05  AO-FILLER            PIC X(87).

       WORKING-STORAGE SECTION.
       01  WS-FILE-STATUS-FLAGS.
           05  WS-ACCT-FILE-STATUS  PIC XX VALUE SPACES.
           05  WS-OUT-FILE-STATUS   PIC XX VALUE SPACES.

       01  WS-CONTROL-FIELDS.
           05  WS-RECORD-COUNT      PIC 9(9) COMP VALUE ZERO.
           05  WS-ERROR-COUNT       PIC 9(5) COMP VALUE ZERO.
           05  WS-EOF-FLAG          PIC X    VALUE 'N'.
               88  EOF-REACHED      VALUE 'Y'.
           05  WS-RETURN-CODE       PIC S9(4) COMP VALUE ZERO.

       01  WS-WORK-FIELDS.
           05  WS-ACCT-NUM          PIC 9(10) VALUE ZERO.
           05  WS-CUST-NAME         PIC X(40) VALUE SPACES.
           05  WS-BALANCE-WORK      PIC S9(13)V99 COMP-3 VALUE ZERO.
           05  WS-BALANCE-FORMATTED PIC S9(13)V99 COMP-3 VALUE ZERO.
           05  WS-CREDIT-LIM        PIC S9(11)V99 COMP-3 VALUE ZERO.
           05  WS-DATE-WORK         PIC X(8) VALUE SPACES.
           05  WS-STATUS            PIC X(2) VALUE SPACES.
           05  WS-BRANCH            PIC X(4) VALUE SPACES.
           05  WS-PRODUCT           PIC X(6) VALUE SPACES.

       PROCEDURE DIVISION.
       0000-MAIN-CONTROL.
           PERFORM 1000-INITIALIZE
           PERFORM 2000-PROCESS-RECORDS
               UNTIL EOF-REACHED
           PERFORM 3000-FINALIZE
           STOP RUN.

       1000-INITIALIZE.
           OPEN INPUT  ACCOUNT-MASTER-FILE
           OPEN OUTPUT ACCOUNT-OUTPUT-FILE
           IF WS-ACCT-FILE-STATUS NOT = '00'
               DISPLAY 'ERROR OPENING ACCOUNT-MASTER-FILE: '
                       WS-ACCT-FILE-STATUS
               MOVE 12 TO RETURN-CODE
               STOP RUN
           END-IF
           READ ACCOUNT-MASTER-FILE
               AT END MOVE 'Y' TO WS-EOF-FLAG
           END-READ.

       2000-PROCESS-RECORDS.
           PERFORM 2100-VALIDATE-RECORD
           PERFORM 2200-TRANSFORM-RECORD
           PERFORM 2300-WRITE-OUTPUT
           PERFORM 2400-READ-NEXT.

       2100-VALIDATE-RECORD.
           IF AM-ACCOUNT-NUMBER = ZERO
               ADD 1 TO WS-ERROR-COUNT
               GO TO 2400-READ-NEXT
           END-IF
           IF AM-BALANCE < ZERO
               MOVE 'SU' TO WS-STATUS
           ELSE
               MOVE AM-STATUS-CODE TO WS-STATUS
           END-IF.

       2200-TRANSFORM-RECORD.
           MOVE AM-ACCOUNT-NUMBER  TO WS-ACCT-NUM
           MOVE AM-CUSTOMER-NAME   TO WS-CUST-NAME
           MOVE AM-BALANCE         TO WS-BALANCE-WORK
           COMPUTE WS-BALANCE-FORMATTED =
               WS-BALANCE-WORK * 1.00
           MOVE AM-CREDIT-LIMIT    TO WS-CREDIT-LIM
           MOVE AM-OPEN-DATE       TO WS-DATE-WORK
           MOVE AM-BRANCH-CODE     TO WS-BRANCH
           MOVE AM-PRODUCT-CODE    TO WS-PRODUCT.

       2300-WRITE-OUTPUT.
           MOVE WS-ACCT-NUM            TO AO-ACCOUNT-NUMBER
           MOVE WS-CUST-NAME           TO AO-CUSTOMER-NAME
           MOVE AM-ACCOUNT-TYPE        TO AO-ACCOUNT-TYPE
           MOVE WS-BALANCE-FORMATTED   TO AO-BALANCE
           MOVE WS-DATE-WORK           TO AO-OPEN-DATE
           MOVE WS-STATUS              TO AO-STATUS-CODE
           MOVE WS-CREDIT-LIM          TO AO-CREDIT-LIMIT
           MOVE WS-BRANCH              TO AO-BRANCH-CODE
           MOVE WS-PRODUCT             TO AO-PRODUCT-CODE
           MOVE SPACES                 TO AO-FILLER
           WRITE ACCT-OUTPUT-RECORD
           IF WS-OUT-FILE-STATUS NOT = '00'
               DISPLAY 'ERROR WRITING OUTPUT: ' WS-OUT-FILE-STATUS
               ADD 1 TO WS-ERROR-COUNT
           ELSE
               ADD 1 TO WS-RECORD-COUNT
           END-IF.

       2400-READ-NEXT.
           READ ACCOUNT-MASTER-FILE
               AT END MOVE 'Y' TO WS-EOF-FLAG
           END-READ.

       3000-FINALIZE.
           CLOSE ACCOUNT-MASTER-FILE
           CLOSE ACCOUNT-OUTPUT-FILE
           DISPLAY 'PROG001: RECORDS PROCESSED = ' WS-RECORD-COUNT
           DISPLAY 'PROG001: ERRORS = ' WS-ERROR-COUNT
           IF WS-ERROR-COUNT > 0
               MOVE 4 TO WS-RETURN-CODE
           END-IF
           MOVE WS-RETURN-CODE TO RETURN-CODE.
