//DLYACLD  JOB (ACCT001),'DAILY ACCOUNT LOAD',CLASS=A,
//         MSGCLASS=X,MSGLEVEL=(1,1),NOTIFY=&SYSUID
//*
//*  JOB: DAILY_ACCOUNT_LOAD
//*  PURPOSE: Read account master file, process via COBOL programs,
//*           output account and transaction files for SQL loading.
//*
//JOBLIB   DD DSN=PROD.LOADLIB,DISP=SHR
//*
//*  STEP 1: Run PROG001 - Account extraction
//*
//STEP010  EXEC PGM=PROG001
//STEPLIB  DD DSN=PROD.LOADLIB,DISP=SHR
//SYSOUT   DD SYSOUT=*
//SYSPRINT DD SYSOUT=*
//INFILE   DD DSN=ACCOUNT.MASTER.FILE,DISP=SHR,
//            DCB=(RECFM=FB,LRECL=200,BLKSIZE=2000)
//OUTFILE  DD DSN=ACCOUNT.OUTPUT.FILE,
//            DISP=(NEW,CATLG,DELETE),
//            DCB=(RECFM=FB,LRECL=200,BLKSIZE=2000),
//            SPACE=(TRK,(50,10),RLSE)
//PARMFILE DD DSN=PROD.PARMS(PROG001P),DISP=SHR
//*
//*  STEP 2: Run PROG002 - Transaction validation
//*
//STEP020  EXEC PGM=PROG002,COND=(0,LT,STEP010)
//STEPLIB  DD DSN=PROD.LOADLIB,DISP=SHR
//SYSOUT   DD SYSOUT=*
//SYSPRINT DD SYSOUT=*
//TRANIN   DD DSN=TRANSACTION.INPUT.FILE,DISP=SHR,
//            DCB=(RECFM=FB,LRECL=250,BLKSIZE=2500)
//VALIDOUT DD DSN=VALID.TRANS.OUTPUT,
//            DISP=(NEW,CATLG,DELETE),
//            DCB=(RECFM=FB,LRECL=250,BLKSIZE=2500),
//            SPACE=(TRK,(100,20),RLSE)
//REJECTDS DD DSN=REJECT.TRANS.FILE,
//            DISP=(NEW,CATLG,DELETE),
//            DCB=(RECFM=FB,LRECL=250,BLKSIZE=2500),
//            SPACE=(TRK,(10,5),RLSE)
//*
//*  STEP 3: SQL load - Account summary
//*
//STEP030  EXEC PGM=IKJEFT01,COND=(0,LT,STEP020)
//SYSTSPRT DD SYSOUT=*
//SYSTSIN  DD *
  DSN SYSTEM(DB2P)
  RUN PROGRAM(DSNTEP2) PLAN(DSNTEP2) -
      PARMS('/load_accounts.sql')
  END
//*
//*  STEP 4: SQL load - Transaction detail
//*
//STEP040  EXEC PGM=IKJEFT01,COND=(0,LT,STEP030)
//SYSTSPRT DD SYSOUT=*
//SYSTSIN  DD *
  DSN SYSTEM(DB2P)
  RUN PROGRAM(DSNTEP2) PLAN(DSNTEP2) -
      PARMS('/load_transactions.sql')
  END
//*
