{
  "_comment": "Expected data lineage for Credit Risk MI4014 daily transaction extract pipeline. Use this to validate agentic app output.",
  "flow_name": "MI4014 Credit Risk Daily Transaction Extract",
  "system": "Credit Risk Behaviour Scoring - TSB NAM65",
  "version": "1.0",
  "pipeline_steps": [
    "STEP010: CRDB2EXT (DB2 CRISK.CUST_ACCOUNT_MASTER → CUST.BHSCORE.EXTRACT)",
    "STEP020: CRTXNEXT (CUST.BHSCORE.EXTRACT + DB2 CRISK.DAILY_TRANSACTIONS → TRANS.BHSCORE.EXTRACT)",
    "STEP030: DFSORT JOINKEYS merge (CUST.BHSCORE.EXTRACT + TRANS.BHSCORE.EXTRACT → MERGED.BHSCORE.EXTRACT)",
    "STEP040: CRXMLGEN (MERGED.BHSCORE.EXTRACT → MI4014_Transaction_Extract_TSB_NAM65_YYYYMMDD.xml)",
    "STEP050: FTP transfer (mainframe → Oracle server /app/neptune/load/)",
    "Oracle load: MI4014_TRANSACCIONES_DIARIAS external table → MI4014_TRANSACCIONES_STG staging"
  ],

  "lineage_nodes": [
    {
      "id": "db2:CRISK.CUST_ACCOUNT_MASTER",
      "type": "DataSource",
      "sub_type": "DB2Table",
      "name": "CRISK.CUST_ACCOUNT_MASTER",
      "system": "IBM DB2 (Mainframe)",
      "columns": [
        "EXTERNAL_ACCOUNT_NUMBER", "SUB_ACCOUNT_NUMBER", "BOOK_ID",
        "CUSTOMER_ID", "PRODUCT_TYPE", "RISK_SEGMENT", "BEHAVIOUR_SCORE",
        "UNSECURED_IND", "ACCOUNT_OPEN_DATE", "NEW_MAIN_ACCOUNT_NUMBER",
        "NEW_LOAN_ACCOUNT_NUMBER", "PROCESS_DATE", "ACCOUNT_STATUS",
        "SCORING_ELIGIBLE_IND"
      ]
    },
    {
      "id": "db2:CRISK.DAILY_TRANSACTIONS",
      "type": "DataSource",
      "sub_type": "DB2Table",
      "name": "CRISK.DAILY_TRANSACTIONS",
      "system": "IBM DB2 (Mainframe)",
      "columns": [
        "EXTERNAL_ACCOUNT_NUMBER", "SUB_ACCOUNT_NUMBER", "BOOK_ID",
        "TRANSACTION_CODE", "TRANSACTION_AMT", "TRAN_CATEGORY",
        "POSTED_DATE", "EFFECTIVE_DATE", "UNSECURED_IND",
        "NEW_MAIN_ACCOUNT_NUMBER", "NEW_LOAN_ACCOUNT_NUMBER", "PROCESS_DATE"
      ]
    },
    {
      "id": "program:CRDB2EXT",
      "type": "TransformationUnit",
      "sub_type": "COBOLProgram",
      "name": "CRDB2EXT",
      "language": "COBOL",
      "description": "DB2 cursor-driven extract of eligible customer accounts",
      "copybooks": ["CRCUSTAC"],
      "db2_cursors": ["CSR_CUST_ACCT"],
      "reads_from": ["db2:CRISK.CUST_ACCOUNT_MASTER"],
      "writes_to": ["file:CUST.BHSCORE.EXTRACT"]
    },
    {
      "id": "file:CUST.BHSCORE.EXTRACT",
      "type": "Dataset",
      "sub_type": "MainframeDataset",
      "name": "CUST.BHSCORE.EXTRACT",
      "dsn": "CRISK.BATCH.CUST.BHSCORE.EXTRACT",
      "recfm": "FB",
      "lrecl": 140,
      "description": "Customer account extract - intermediate dataset"
    },
    {
      "id": "program:CRTXNEXT",
      "type": "TransformationUnit",
      "sub_type": "COBOLProgram",
      "name": "CRTXNEXT",
      "language": "COBOL",
      "description": "Transaction extract: reads CUST file, queries DB2 per account",
      "copybooks": ["CRCUSTAC", "CRTRANSR"],
      "db2_cursors": ["CSR_DAILY_TXN"],
      "reads_from": [
        "file:CUST.BHSCORE.EXTRACT",
        "db2:CRISK.DAILY_TRANSACTIONS"
      ],
      "writes_to": ["file:TRANS.BHSCORE.EXTRACT"]
    },
    {
      "id": "file:TRANS.BHSCORE.EXTRACT",
      "type": "Dataset",
      "sub_type": "MainframeDataset",
      "name": "TRANS.BHSCORE.EXTRACT",
      "dsn": "CRISK.BATCH.TRANS.BHSCORE.EXTRACT",
      "recfm": "FB",
      "lrecl": 160,
      "description": "Transaction extract - intermediate dataset"
    },
    {
      "id": "utility:DFSORT_STEP030",
      "type": "TransformationUnit",
      "sub_type": "JCLUtility",
      "name": "DFSORT JOINKEYS MERGE (CRJBHSCR STEP030)",
      "language": "JCL_SORT",
      "description": "DFSORT JOINKEYS inner join merge on ACCT+SUB_ACCT; sorts by account, posted_date desc",
      "reads_from": [
        "file:CUST.BHSCORE.EXTRACT",
        "file:TRANS.BHSCORE.EXTRACT"
      ],
      "writes_to": ["file:MERGED.BHSCORE.EXTRACT"],
      "sort_key": "EXTERNAL_ACCT_NUM(1,20)+SUB_ACCT_NUM(21,10)+POSTED_DATE(77,10)_DESC"
    },
    {
      "id": "file:MERGED.BHSCORE.EXTRACT",
      "type": "Dataset",
      "sub_type": "MainframeDataset",
      "name": "MERGED.BHSCORE.EXTRACT",
      "dsn": "CRISK.BATCH.MERGED.BHSCORE.EXTRACT",
      "recfm": "FB",
      "lrecl": 160,
      "description": "Sorted and merged transaction+account extract"
    },
    {
      "id": "program:CRXMLGEN",
      "type": "TransformationUnit",
      "sub_type": "COBOLProgram",
      "name": "CRXMLGEN",
      "language": "COBOL",
      "description": "XML generator: reads merged extract, writes Oracle-compatible XML",
      "copybooks": ["CRTRANSR", "CRXMLTAG"],
      "reads_from": ["file:MERGED.BHSCORE.EXTRACT"],
      "writes_to": ["file:MI4014_XML"]
    },
    {
      "id": "file:MI4014_XML",
      "type": "Dataset",
      "sub_type": "XMLFile",
      "name": "MI4014_Transaction_Extract_TSB_NAM65_YYYYMMDD.xml",
      "path": "/app/neptune/load/MI4014_Transaction_Extract_TSB_NAM65_YYYYMMDD.xml",
      "directory": "NEPTUNE_FILES_LOAD",
      "description": "XML transaction extract for Oracle external table load"
    },
    {
      "id": "oracle:BDD_NEPTUNE_DICC.MI4014_TRANSACCIONES_DIARIAS",
      "type": "DataSource",
      "sub_type": "OracleExternalTable",
      "name": "BDD_NEPTUNE_DICC.MI4014_TRANSACCIONES_DIARIAS",
      "system": "Oracle",
      "schema": "BDD_NEPTUNE_DICC",
      "table": "MI4014_TRANSACCIONES_DIARIAS",
      "table_type": "EXTERNAL",
      "reads_from": ["file:MI4014_XML"],
      "columns": [
        "MAIN_ACCOUNT_NUMBER", "SUB_ACCOUNT_NUMBER", "COMPANY",
        "TRANSACTION_CODE", "TRANSACTION_AMOUNT", "TRANSACTION_GROUP",
        "POSTED_DATE", "EFFECTIVE_DATE", "UNSECURED",
        "NEW_MAIN_ACC_NUM", "NEW_LOAN_ACC_NUM"
      ]
    },
    {
      "id": "oracle:BDD_NEPTUNE_DICC.MI4014_TRANSACCIONES_STG",
      "type": "Dataset",
      "sub_type": "OracleTable",
      "name": "BDD_NEPTUNE_DICC.MI4014_TRANSACCIONES_STG",
      "system": "Oracle",
      "schema": "BDD_NEPTUNE_DICC",
      "table": "MI4014_TRANSACCIONES_STG",
      "columns": [
        "MAIN_ACCOUNT_NUMBER", "SUB_ACCOUNT_NUMBER", "COMPANY",
        "TRANSACTION_CODE", "TRANSACTION_AMOUNT", "TRANSACTION_GROUP",
        "POSTED_DATE", "EFFECTIVE_DATE", "UNSECURED",
        "NEW_MAIN_ACC_NUM", "NEW_LOAN_ACC_NUM",
        "LOAD_DATE", "SOURCE_FILE", "LOAD_STATUS"
      ]
    },
    {
      "id": "sql:MI4014_STAGE_INSERT",
      "type": "TransformationUnit",
      "sub_type": "SQLScript",
      "name": "MI4014_STAGE_LOAD.sql INSERT",
      "language": "SQL_ORACLE",
      "description": "INSERT INTO MI4014_STG from external table with type casting",
      "reads_from": ["oracle:BDD_NEPTUNE_DICC.MI4014_TRANSACCIONES_DIARIAS"],
      "writes_to": ["oracle:BDD_NEPTUNE_DICC.MI4014_TRANSACCIONES_STG"]
    },
    {
      "id": "oracle:BDD_NEPTUNE_DICC.V_MI4014_TRANSACCIONES_VALIDAS",
      "type": "Dataset",
      "sub_type": "OracleView",
      "name": "V_MI4014_TRANSACCIONES_VALIDAS",
      "reads_from": ["oracle:BDD_NEPTUNE_DICC.MI4014_TRANSACCIONES_STG"]
    },
    {
      "id": "oracle:BDD_NEPTUNE_DICC.V_MI4014_ACCOUNT_SUMMARY",
      "type": "Dataset",
      "sub_type": "OracleView",
      "name": "V_MI4014_ACCOUNT_SUMMARY",
      "reads_from": ["oracle:BDD_NEPTUNE_DICC.V_MI4014_TRANSACCIONES_VALIDAS"]
    }
  ],

  "lineage_edges": [
